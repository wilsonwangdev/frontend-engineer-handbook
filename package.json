{
  "name": "frontend-engineer-handbook",
  "version": "0.0.1",
  "private": true,
  "description": "围绕 agent 协作的前端工程师中文精编手册。",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/check-sequential.mjs && node scripts/build-search-index.mjs && next build",
    "start": "next start",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:local": "PLAYWRIGHT_SKIP_WEBSERVER=1 playwright test",
    "smoke": "node scripts/smoke.mjs",
    "links": "node scripts/check-links.mjs",
    "check-seq": "node scripts/check-sequential.mjs",
    "check-fm": "node scripts/check-frontmatter.mjs",
    "ci": "pnpm run check-seq && pnpm run check-fm && pnpm run type-check && pnpm run lint && pnpm run format:check && pnpm run test && pnpm run build",
    "prepare": "husky"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "next": "^16.2.7",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reading-time": "^1.5.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@playwright/test": "^1.60.0",
    "@size-limit/preset-app": "^12.1.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "babel-plugin-react-compiler": "^1.0.0",
    "husky": "^9.1.7",
    "js-yaml": "^4.2.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.68.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "rehype-pretty-code": "^0.14.3",
    "size-limit": "^12.1.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "zod": "^4.4.3"
  }
}
