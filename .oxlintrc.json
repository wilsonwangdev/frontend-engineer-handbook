{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "warn",
    "style": "off"
  },
  "rules": {
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "no-debugger": "error",
    "react/jsx-key": "error",
    "react/jsx-no-target-blank": "error"
  },
  "ignorePatterns": [
    "node_modules",
    ".next",
    "out",
    "dist",
    "coverage",
    "playwright-report",
    "test-results"
  ]
}
